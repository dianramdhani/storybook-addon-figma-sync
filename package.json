{
  "name": "storybook-addon-figma-sync",
  "version": "0.0.0",
  "description": "Addon Storybook untuk membantu sync figma",
  "keywords": [
    "storybook-addon"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dianramdhani/storybook-addon-figma-sync"
  },
  "license": "MIT",
  "author": "Dian Ramdhani Lubis <dian.ramdhani@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./preset": "./dist/preset.js",
    "./manager": "./dist/manager.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "build": "tsup",
    "build-storybook": "storybook build",
    "build:watch": "yarn build --watch",
    "commitlint": "commitlint",
    "eject-ts": "zx scripts/eject-typescript.js",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache . --fix",
    "prepare": "husky",
    "prepublishOnly": "node -e \"const fs = require('fs'); fs.renameSync('README.md', 'README-INTERNAL.md'); fs.copyFileSync('README-NPM.md', 'README.md');\"",
    "postpublish": "node -e \"const fs = require('fs'); fs.renameSync('README-INTERNAL.md', 'README.md');\"",
    "prerelease": "zx scripts/prepublish-checks.js",
    "release": "yarn build && auto shipit",
    "start": "yarn build && run-p build:watch \"storybook --quiet\"",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "vitest run"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/geist": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@storybook/addon-docs": "next",
    "@storybook/icons": "^2.0.0",
    "@storybook/react-vite": "next",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "auto": "^11.3.6",
    "boxen": "^8.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "next",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "lucide-react": "^1.18.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "next",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "ts-dedent": "^2.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "storybook": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": "prettier --write"
  },
  "bundler": {
    "managerEntries": [
      "src/manager.tsx"
    ],
    "previewEntries": [
      "src/preview.ts",
      "src/index.ts"
    ],
    "nodeEntries": [
      "src/preset.ts"
    ]
  },
  "storybook": {
    "displayName": "Figma Sync",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://segosambel-poc-bucket.s3.ap-southeast-3.amazonaws.com/sentri/sentri-logo.png"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "dotenv": "^17.4.2",
    "html-to-image": "^1.11.13",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0"
  }
}
